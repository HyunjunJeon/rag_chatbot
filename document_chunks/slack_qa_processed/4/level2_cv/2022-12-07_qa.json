      "answers": [
        {
          "text": "시드 탐색이라.. 생각도 못해봤는데 2-c가 그나마 현실적이어 보이네요 ㅎㅎ 새로운 아이디어 얻고 갑니다 감사합니다",
          "user": "U041L8WPYKW",
          "user_name": "류건",
          "timestamp": "1670422737.532969",
          "is_bot": false,
          "metadata": {
            "edited": null,
            "reactions": null,
            "reply_count": 0
