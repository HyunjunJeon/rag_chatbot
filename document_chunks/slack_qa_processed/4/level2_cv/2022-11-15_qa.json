              }
            ],
            "reply_count": 0
          }
        },
        {
          "text": "감사합니다!",
          "user": "U0427G48WAC",
          "user_name": "시형",
          "timestamp": "1668556451.350969",
          "is_bot": false,
          "metadata": {
            "edited": null,
            "reactions": null,
