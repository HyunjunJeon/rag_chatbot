                "count": 5
              }
            ],
            "reply_count": 0
          }
        },
        {
          "text": "모두 감사합니다!",
          "user": "U09CH7ZHVJP",
          "user_name": "송현우",
          "timestamp": "1756720751.645999",
          "is_bot": false,
